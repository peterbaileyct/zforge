{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run ZForge (module)",
      "type": "debugpy",
      "request": "launch",
      "module": "zforge",
      "console": "integratedTerminal",
      "justMyCode": true,
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      }
    },
    {
      "name": "zforge (dart)",
      "request": "launch",
      "type": "dart"
    },
    {
      "name": "zforge (profile mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile"
    },
    {
      "name": "zforge (release mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release"
    }
  ]
}